# AgentCore Runtime Configuration
VITE_AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/your-runtime-id
VITE_AWS_REGION=us-east-1

# Cognito Configuration (for login)
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Preset Auth Token (for backward compatibility)
# If set, users can skip login and use this token directly
VITE_AUTH_TOKEN=your-cognito-access-token

# API Proxy (for local development)
VITE_API_PROXY_URL=http://localhost:8080
